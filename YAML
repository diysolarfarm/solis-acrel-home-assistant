modbus:
  - name: acrel_meter
    type: tcp
    host: 192.168.88.148
    port: 502
    delay: 0
    message_wait_milliseconds: 100
    timeout: 3

    sensors:
      - name: "Current L1"
        unique_id: current_l1
        slave: 2
        address: 43
        input_type: holding
        data_type: uint16
        unit_of_measurement: A
        device_class: current
        state_class: measurement
        scale: 0.1
        precision: 1
        scan_interval: 1

      - name: "Current L2"
        unique_id: current_l2
        slave: 2
        address: 44
        input_type: holding
        data_type: uint16
        unit_of_measurement: A
        device_class: current
        state_class: measurement
        scale: 0.1
        precision: 1
        scan_interval: 1
